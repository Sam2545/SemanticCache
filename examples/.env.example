# Copy to .env (gitignored) or export these before running the demo.

# SemCache service
SEMCACHE_URL=http://localhost:8000
SEMCACHE_NAMESPACE=llm-demo
SEMCACHE_THRESHOLD=0.82

# --- Chat / answer generation: Ollama Cloud (ollama.com) ---
# Get a key at https://ollama.com/settings/keys
CHAT_BASE_URL=https://ollama.com/v1
CHAT_API_KEY=replace-with-your-ollama-com-key
CHAT_MODEL=gpt-oss:120b

# --- Embeddings: local Ollama (Ollama Cloud has NO embedding models) ---
# Requires a local Ollama: `ollama pull nomic-embed-text`
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=nomic-embed-text

# Both sides speak the OpenAI-compatible API, so you can repoint either one at
# any compatible provider (OpenAI, a fully-local Ollama for chat too, etc.).
